# Xcode
*.xcuserdata
*.xcscmblueprint
xcuserdata/
DerivedData/
build/

# Secrets — Secrets.xcconfig is intentionally committed because the values
# inside it (legacy Supabase anon JWT + pk Mapbox public token + project URL)
# all ship in the client IPA anyway and are designed to be public. The only
# truly-secret value (MAPBOX_DOWNLOADS_TOKEN, sk.…) lives in ~/.netrc locally
# and as a Shared env var on Xcode Cloud — not in this file. Rotate the
# committed values via the Supabase + Mapbox dashboards before launch.

# macOS
.DS_Store

# Python tools
__pycache__/
*.pyc

# Claude worktrees
.claude/worktrees/

# Cursor
.cursor/

# Local audit/scratch notes
AUDIT_*.md

# Supabase CLI scratch
supabase/.temp/

# Local-only files that must never enter the repo. Holds:
#   _local/media/    — demo screenshots, video captures, marketing assets
#   _local/secrets/  — APNs .p8 keys, any other plaintext credentials
# Anything that should stay on the dev machine but doesn't belong in
# git lives here. Single umbrella so contributors only need to remember
# one ignore rule.
_local/
